#!/usr/bin/env bash
set -e

echo "=== Pre-commit hook ==="

# Determine mode and step count
if [ "${PRECOMMIT_QUICK:-}" = "1" ]; then
  TOTAL=6
  echo "(quick mode — set PRECOMMIT_QUICK=0 or unset for full checks)"
else
  TOTAL=11
fi
STEP=0

next_step() {
  STEP=$((STEP + 1))
  echo "[$STEP/$TOTAL] $1"
}

next_step "Checking prerequisites..."
if ! dotnet run scripts/worktree-setup.cs -- --check 2>/dev/null; then
  echo "  -> Auto-fixing: running worktree-setup.cs..."
  dotnet run scripts/worktree-setup.cs
fi

next_step "Regenerating api.d.ts if openapi/spec.yaml is staged..."
SPEC_STAGED="$(git diff --cached --name-only -- openapi/spec.yaml 2>/dev/null || true)"
if [ -n "$SPEC_STAGED" ]; then
  echo "  -> openapi/spec.yaml staged — running npm run generate:types:write"
  (cd src/client && npm run generate:types:write --silent)
  if ! git diff --quiet -- src/client/src/generated/api.d.ts; then
    echo "  -> api.d.ts drifted; staging regenerated file"
    git add src/client/src/generated/api.d.ts
  fi
else
  echo "  -> openapi/spec.yaml not staged; skipping"
fi

if [ "${PRECOMMIT_QUICK:-}" != "1" ]; then
  next_step "Linting OpenAPI spec..."
  NODE_OPTIONS="--disable-warning=DEP0040" npx spectral lint openapi/spec.yaml --fail-severity warn
fi

next_step "Checking EF migration integrity..."
MIGRATION_DIR="src/Infrastructure/Migrations"
MISSING=0
for migration in "$MIGRATION_DIR"/*.cs; do
  base="$(basename "$migration")"
  # Skip Designer files and the Snapshot
  case "$base" in
    *.Designer.cs|*ModelSnapshot.cs) continue ;;
  esac
  designer="${migration%.cs}.Designer.cs"
  if [ ! -f "$designer" ]; then
    echo "  ERROR: Missing Designer file for migration: $base"
    echo "         Expected: $(basename "$designer")"
    MISSING=$((MISSING + 1))
  fi
done
if [ "$MISSING" -gt 0 ]; then
  echo ""
  echo "  $MISSING migration(s) missing Designer files."
  echo "  EF Core will silently skip these migrations."
  echo "  Regenerate with: dotnet ef migrations add <Name> --project src/Infrastructure --startup-project src/Presentation/API"
  exit 1
fi

next_step "Checking code formatting..."
dotnet format Receipts.slnx --verify-no-changes

if [ "${PRECOMMIT_QUICK:-}" != "1" ]; then
  next_step "Building with warnings-as-errors..."
  # Provide a build-time JWT key so GenerateOpenApiDocuments can start the host.
  # At runtime the real key is required via appsettings/Aspire configuration.
  Jwt__Key=build-time-spec-extraction-only-not-for-runtime \
  dotnet build Receipts.slnx -p:TreatWarningsAsErrors=true --no-restore

  next_step "Checking spec drift..."
  node scripts/check-drift.mjs

  next_step "Running .NET tests..."
  dotnet test Receipts.slnx --no-build --verbosity normal --filter "Category!=Integration"
fi

next_step "Checking TypeScript types..."
npx tsc -b src/client/tsconfig.json --noEmit

next_step "Linting React client..."
npx eslint src/client/src

if [ "${PRECOMMIT_QUICK:-}" != "1" ]; then
  next_step "Running frontend tests (vitest)..."
  (cd src/client && npx vitest run)
fi

echo "=== All checks passed ==="
