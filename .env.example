# Docker Compose production environment variables
# Copy to .env and fill in values before running docker compose up

# --- Docker Image ---
IMAGE_TAG=latest

# --- Sentry (passed as Docker build args via CI) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_...  (for source map uploads in CI)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=receipts-frontend
