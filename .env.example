# Receipts Docker Deployment Configuration
# Copy to .env and fill in values before running docker compose up.
# Generate secrets: bash scripts/generate-secrets.sh > .env
# NEVER commit .env to source control.

# ─── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL credentials used by both the db container and the app container.
POSTGRES_USER=receipts
POSTGRES_PASSWORD=          # REQUIRED — use generate-secrets.sh
POSTGRES_DB=receipts

# ─── Authentication ─────────────────────────────────────────────────────────────
# JWT signing key (min 32 chars). Signs and verifies access tokens.
JWT_KEY=                    # REQUIRED — use generate-secrets.sh
JWT_ISSUER=receipts-api
JWT_AUDIENCE=receipts-app

# ─── Admin Seed ─────────────────────────────────────────────────────────────────
# Initial admin account created on first run. Change email/name as needed.
# Password must satisfy ASP.NET Identity rules: uppercase, lowercase, digit,
# special character, minimum 8 characters.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=             # REQUIRED — use generate-secrets.sh
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ─── Application ────────────────────────────────────────────────────────────────
# Host port the app is exposed on (container always listens on 8080 internally).
APP_PORT=8080

# Docker image tag to pull (default: latest).
IMAGE_TAG=latest
