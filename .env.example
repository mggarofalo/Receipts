# Receipts Docker Deployment Configuration
# Copy to .env and fill in values before running docker compose up

# PostgreSQL
POSTGRES_USER=receipts
POSTGRES_PASSWORD=CHANGE_ME_generate_with_scripts_generate_secrets_sh
POSTGRES_DB=receipts

# JWT Authentication
JWT_KEY=CHANGE_ME_generate_with_scripts_generate_secrets_sh
JWT_ISSUER=receipts-api
JWT_AUDIENCE=receipts-app

# Admin Seed (first-run only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_set_a_strong_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Deployment
IMAGE_TAG=latest
APP_PORT=8080
