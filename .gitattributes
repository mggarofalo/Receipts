# Ensure consistent line endings across platforms
# .editorconfig specifies end_of_line = crlf for C# files
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.slnx text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.razor text eol=crlf
*.cshtml text eol=crlf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.traineddata binary

# Generated OpenAPI TypeScript types — always regenerate rather than hand-merge.
# The post-merge hook regenerates from openapi/spec.yaml when the spec changes.
src/client/src/generated/api.d.ts merge=ours
